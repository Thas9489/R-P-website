# ============================================================
# DATABASE
# ============================================================
DATABASE_URL="postgresql://user:password@localhost:5432/resume_builder"

# ============================================================
# NEXTAUTH
# ============================================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-nextauth-secret-change-this"

# ============================================================
# OAUTH PROVIDERS
# ============================================================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ============================================================
# CLOUDINARY (Image Storage)
# ============================================================
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ============================================================
# AI PROVIDER
# Options: "openai" | "openrouter" | "gemini"
# ============================================================
AI_PROVIDER="openai"
AI_MODEL="gpt-4-turbo-preview"

OPENAI_API_KEY=""

# OpenRouter (alternative - supports many models)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-4-turbo"

# Google Gemini
GEMINI_API_KEY=""

# ============================================================
# APP
# ============================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ResumeAI"
